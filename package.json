{
  "name": "draw-steel-elements",
  "version": "6.0.0-rc1",
  "description": "Components to support the Draw Steel TTRPG by MCDM.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "build-no-check": "node esbuild.config.mjs production",
    "harness:build": "node visual-harness/esbuild.mjs",
    "shots": "npm run harness:build && node visual-harness/shoot.mjs",
    "shot-url": "node visual-harness/shoot-url.mjs",
    "obsidian-shots": "node visual-harness/notes-gen.mjs && npm run build-no-check && node visual-harness/obsidian-camera.mjs",
    "test": "jest",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "tsc": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Steel Compendium",
  "license": "MIT",
  "engines": {
    "node": ">=22.15"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "ajv-keywords": "^5.1.0"
  },
  "devDependencies": {
    "@codemirror/language": "^6.11.3",
    "@types/css": "^0.0.38",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "8.41.0",
    "@typescript-eslint/parser": "8.41.0",
    "builtin-modules": "5.0.0",
    "css": "^3.0.0",
    "esbuild": "0.25.9",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.4.1",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "jszip-utils": "^0.1.0",
    "lucide": "^1.24.0",
    "marked": "^18.0.6",
    "obsidian": "1.8.7",
    "playwright": "^1.61.1",
    "steel-compendium-sdk": "file:../data-sdk-npm",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tslib": "2.8.1",
    "typescript": "5.9.2",
    "yaml": "^2.9.0"
  }
}
